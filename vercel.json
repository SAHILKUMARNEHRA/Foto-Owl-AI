{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/web/index.html"
    },
    {
      "source": "/app.js",
      "destination": "/frontend/web/app.js"
    },
    {
      "source": "/styles.css",
      "destination": "/frontend/web/styles.css"
    }
  ]
}
