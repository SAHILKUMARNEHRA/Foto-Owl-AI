{
  "version": 2,
  "builds": [
    {
      "src": "frontend/web/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/web/app.js",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/web/styles.css",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/app.js",
      "dest": "/frontend/web/app.js"
    },
    {
      "src": "/styles.css",
      "dest": "/frontend/web/styles.css"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/web/index.html"
    }
  ]
}
